# ── Supabase ───────────────────────────────────────────────────────────────
# Get these at: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # NOT the anon key

# ── Reddit ─────────────────────────────────────────────────────────────────
# Create an app at: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=FGCScout/1.0 (by /u/your-username)

# Comma-separated subreddits to track (no r/ prefix)
REDDIT_SUBREDDITS=Tekken,Tekken8,kappa,StreetFighter,Guiltygear

# ── Twitter / X ────────────────────────────────────────────────────────────
# Get this at: https://developer.twitter.com → Projects & Apps → Keys
# Free tier (v2 Basic) is enough — read-only access
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Comma-separated @handles to track (no @ prefix)
TWITTER_ACCOUNTS=Harada_TEKKEN,TekkenEsports,HomeOfTekken,NamcoBandaiUS,JDCR_Tekken

# Keywords to search for in recent tweets (URL-encoded comma list)
TWITTER_KEYWORDS=tekken8,tekken patch,fgc,tekken tier list

# ── YouTube ────────────────────────────────────────────────────────────────
# Get this at: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Comma-separated channel IDs to track
# Find a channel ID: go to channel page → view source → search "channelId"
YOUTUBE_CHANNEL_IDS=UCo8bcnLyZH8tBIH9V1mLgqQ,UCAW-NpUFkMyCNrvRSSGIvDQ

# Search terms to pull trending FGC videos
YOUTUBE_SEARCH_TERMS=tekken 8,tekken tier list,fgc highlights

# ── App ────────────────────────────────────────────────────────────────────
# Secret token to protect your cron endpoint from unauthorized calls
CRON_SECRET=make-this-a-long-random-string

# How many items to keep per platform in the DB
FEED_MAX_ITEMS_PER_SOURCE=50
